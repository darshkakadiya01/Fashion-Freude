{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.18.1",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "browser-image-compression": "^2.0.2",
    "multer": "^2.2.0",
    "react": "^19.2.7",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.18.1",
    "react-scripts": "^5.0.1",
    "slugify": "^1.6.9",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "tw:build": "tailwindcss -i src/styles/tailwind.src.css -o src/styles/index.css --minify",
    "tw:watch": "tailwindcss -i src/styles/tailwind.src.css -o src/styles/index.css --watch",
    "prestart": "npm run tw:build",
    "start": "concurrently -k -r -n tw,cra -c magenta,cyan \"npm run tw:watch\" \"react-scripts start\"",
    "prebuild": "npm run tw:build",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.5.4",
    "concurrently": "^9.2.4",
    "postcss": "^8.5.22",
    "tailwindcss": "^3.4.17"
  }
}
