# Production template. Copy to `server/.env.production` and fill in real values:
#   cp server/.env.production.example server/.env.production
#
# `.env.production` is gitignored — never commit real credentials.
#
# On Hostinger you can skip the file entirely and set these in the Web App's
# environment-variables panel instead; injected variables always take precedence.

NODE_ENV=production

# Public origin of the API (used for absolute URLs, e.g. the sitemap route)
BASE_URL=https://api.fashionfreude.com

# Database (MySQL) — Hostinger prefixes names, e.g. u401306054_shopsphere
DB_HOST=localhost
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# Secret used to sign JWTs. Generate one with: openssl rand -hex 48
JWT_SECRET=

# Comma-separated origins allowed to call the API (no trailing slash)
CORS_ORIGIN=https://fashionfreude.com,https://www.fashionfreude.com

# Leave unset. Enabling it makes Sequelize re-add a duplicate unique index on every boot.
# DB_SYNC_ALTER=false

# Do NOT set PORT on Hostinger — the platform injects it.
