PORT=5000

BASE_URL=http://localhost:5000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=shopsphere
DB_USER=root
DB_PASSWORD=
# Set to true only when you change Sequelize models and want the schema auto-altered.
# Leaving it off avoids duplicate-index accumulation on every restart.
DB_SYNC_ALTER=false

# Secret used to sign JWTs. Generate one with: openssl rand -hex 48
JWT_SECRET=
